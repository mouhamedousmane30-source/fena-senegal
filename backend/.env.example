# Configuration Backend - Feñ Na Sénégal
# Copiez ce fichier en .env et remplissez les valeurs

# Port du serveur (Render utilise souvent 10000)
PORT=10000

# MongoDB Atlas URI
# Format: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://fena_admin:votre_mot_de_passe@cluster0.xxxxx.mongodb.net/fena_db?retryWrites=true&w=majority

# JWT Secret (min 32 caractères, complexe)
JWT_SECRET=votre_secret_jwt_tres_long_et_complexe_32_caracteres_min

# Environment
NODE_ENV=production
